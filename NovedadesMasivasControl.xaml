<UserControl x:Class="prueba1.NovedadesMasivasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Centro de Asignación Masiva" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="Asigna comisiones, vacaciones y permisos con cálculo inteligente de tiempos." FontSize="14" Foreground="#64748B" Margin="0,0,0,20"/>

        <Border Grid.Row="2" CornerRadius="12" Background="White" ClipToBounds="True" Margin="0,0,0,20">
            <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="15">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="🔍 Buscar:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#475569" Margin="0,0,10,0"/>
                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White">
                                <TextBox x:Name="txtBuscarMasivo" Width="250" Height="36" Padding="10,0" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" TextChanged="TxtBuscarMasivo_TextChanged" ToolTip="Escribe un nombre o matrícula..."/>
                            </Border>
                            
                            <TextBlock Text="Filtrar Área:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#475569" Margin="20,0,10,0"/>
                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White">
                                <ComboBox x:Name="cmbFiltroArea" Width="150" Height="36" Padding="10,0" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" SelectionChanged="CmbFiltroArea_SelectionChanged">
                                    <ComboBoxItem Content="TODAS LAS ÁREAS" IsSelected="True"/>
                                    <ComboBoxItem Content="Talleres"/>
                                    <ComboBoxItem Content="Servicios"/>
                                    <ComboBoxItem Content="Detall"/>
                                    <ComboBoxItem Content="Comunav"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="☑️ Marcar Todos" Background="#E2E8F0" Foreground="#1E293B" FontWeight="Bold" Padding="15,8" Margin="0,0,10,0" Click="BtnSeleccionarTodos_Click">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                            </Button>
                            <Button Content="🔲 Desmarcar" Background="#F1F5F9" Foreground="#64748B" FontWeight="Bold" Padding="15,8" Click="BtnDeseleccionarTodos_Click">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid x:Name="dgMasivo" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="White" RowHeight="55" AlternatingRowBackground="#F8FAFC" 
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="15,10"/>
                        </Style>
                        <Style TargetType="ToolTip">
                            <Setter Property="Background" Value="#0F172A"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="15"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HasDropShadow" Value="True"/>
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </DataGrid.Resources>
                    
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EstatusActual}" Value="BAJA">
                                    <Setter Property="Opacity" Value="0.5"/>
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="☑ Sel." Binding="{Binding Seleccionado, UpdateSourceTrigger=PropertyChanged}" Width="70">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/></Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>
                        
                        <DataGridTextColumn Header="Matrícula" Binding="{Binding Matricula}" Width="100" IsReadOnly="True" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Nombre Completo" Binding="{Binding Nombre}" Width="260" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Área" Binding="{Binding Area}" Width="110" IsReadOnly="True"/>
                        
                        <DataGridTemplateColumn Header="Estado" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding EstatusColorFondo}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding EstatusActual}" Foreground="{Binding EstatusColorTexto}" FontWeight="Bold" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Situación Actual (Pasa el mouse)" Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ColorFondo}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="{Binding NovedadTooltip}">
                                        <TextBlock Text="{Binding NovedadDisplay}" Foreground="{Binding ColorTexto}" FontWeight="Bold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Tiempo Restante" Binding="{Binding TiempoRestante}" Width="*" IsReadOnly="True" FontWeight="Bold"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="12" Padding="20">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                
                <TextBlock Text="Acción a realizar:" VerticalAlignment="Center" FontWeight="Black" Foreground="#0284C7" Margin="0,0,10,0"/>
                <Border BorderBrush="#7DD3FC" BorderThickness="2" CornerRadius="6" Background="White" Margin="0,0,25,0">
                    <ComboBox x:Name="cmbTipoAccion" Width="200" Height="40" Padding="10,0" BorderThickness="0" SelectionChanged="CmbTipoAccion_SelectionChanged" VerticalContentAlignment="Center" FontWeight="Bold">
                        <ComboBoxItem Content="Asignar Situación/Novedad" IsSelected="True" Tag="NOVEDAD"/>
                        <ComboBoxItem Content="Cambiar Estado (Alta/Baja)" Tag="ESTATUS"/>
                    </ComboBox>
                </Border>

                <StackPanel x:Name="panelNovedad" Orientation="Horizontal" Visibility="Visible">
                    <TextBlock Text="Novedad:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,15,0">
                        <ComboBox x:Name="cmbMasivoNovedad" Width="140" Height="40" Padding="10,0" BorderThickness="0" VerticalContentAlignment="Center" SelectionChanged="CmbMasivoNovedad_SelectionChanged">
                            <ComboBoxItem Content="PRESENTE" Tag="PRESENTE" IsSelected="True"/>
                            <ComboBoxItem Content="VACACIONES" Tag="VACACIONES"/>
                            <ComboBoxItem Content="PERMISO" Tag="PERMISO"/>
                            <ComboBoxItem Content="COMISION" Tag="COMISION"/>
                            <ComboBoxItem Content="HOSPITALIZADO" Tag="HOSPITALIZADO"/>
                            <ComboBoxItem Content="REBAJADO" Tag="REBAJADO"/>
                            <ComboBoxItem Content="FRANQUICIA" Tag="FRANQUICIA"/>
                            <ComboBoxItem Content="ARRESTO" Tag="ARRESTO"/>
                        </ComboBox>
                    </Border>

                    <StackPanel x:Name="panelDetalles" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="Lugar/Detalle:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,15,0">
                            <TextBox x:Name="txtMasivoDetalle" Width="160" Height="40" Padding="10,0" BorderThickness="0" VerticalContentAlignment="Center" ToolTip="Ej: Operación Patria, Torre Pemex..."/>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="panelFechas" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="Del:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpMasivoInicio" Width="110" Height="40" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        
                        <StackPanel x:Name="panelFechaFin" Orientation="Horizontal">
                            <TextBlock Text="Al:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpMasivoFin" Width="110" Height="40" Margin="0,0,15,0" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="chkMasivoIndefinido" Content="Sin fecha retorno (Indefinido)" VerticalAlignment="Center" FontWeight="Bold" Foreground="#DC2626" Margin="0,0,15,0" Checked="ChkMasivoIndefinido_Checked" Unchecked="ChkMasivoIndefinido_Unchecked"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="panelEstatus" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Nuevo Estado:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,30,0">
                        <ComboBox x:Name="cmbMasivoEstatus" Width="160" Height="40" Padding="10,0" BorderThickness="0" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="ACTIVO" Tag="ACTIVO" IsSelected="True"/>
                            <ComboBoxItem Content="BAJA" Tag="BAJA"/>
                        </ComboBox>
                    </Border>
                </StackPanel>

                <Button x:Name="btnAplicarCambios" Content="🚀 APLICAR A SELECCIONADOS" Background="#0284C7" Foreground="White" FontWeight="Bold" FontSize="14" Padding="25,0" Height="40" Margin="10,0,0,0" Click="BtnAplicarMasivo_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>