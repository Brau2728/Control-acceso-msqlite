<UserControl x:Class="prueba1.SistemaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración del Sistema y Respaldos" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,30"/>
        
        <WrapPanel Grid.Row="1" Orientation="Horizontal">
            <!-- Tarjeta Respaldo -->
            <Border Background="White" CornerRadius="12" Padding="30" Width="320" Margin="0,0,30,30">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="💾 Copia de Seguridad" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,10,10"/>
                    <TextBlock Text="Crea un respaldo completo de la base de datos (Personal, Huellas, Registros)." TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,20" Height="60"/>
                    <Button Content="Generar Respaldo DB" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="15,12" Click="BtnRespaldo_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Tarjeta Restaurar -->
            <Border Background="White" CornerRadius="12" Padding="30" Width="320" Margin="0,0,30,30">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="🔄 Restaurar Sistema" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                    <TextBlock Text="Restaura la base de datos desde un archivo de respaldo (.db o .bak)." TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,20" Height="60"/>
                    <Button Content="Restaurar desde Archivo" Background="#F59E0B" Foreground="White" FontWeight="Bold" Padding="15,12" Click="BtnRestaurar_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Tarjeta Excel (En progreso) -->
            <Border Background="White" CornerRadius="12" Padding="30" Width="320" Margin="0,0,30,30">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="📊 Carga Masiva (Excel)" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                    <TextBlock Text="Importa novedades o personal desde una plantilla de Excel. (Módulo en construcción)." TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,20" Height="60"/>
                    <Button Content="Modulo a desarollar" Background="#94A3B8" Foreground="White" FontWeight="Bold" Padding="15,12" IsEnabled="False">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </WrapPanel>
    </Grid>
</UserControl>