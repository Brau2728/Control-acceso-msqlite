<Window x:Class="prueba1.RegistroPersonal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alta de Personal Naval" Height="600" Width="850"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F5F5F5">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#00204A">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border x:Name="bdrFoto" Width="160" Height="190" Background="White" CornerRadius="5" Margin="0,0,0,15" ClipToBounds="True">
                    <Image x:Name="imgFoto" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="stEscala" ScaleX="1" ScaleY="1"/>
                                <RotateTransform x:Name="rtRotacion" Angle="0"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Button Content="↺" Width="35" Height="35" Margin="3" Click="BtnRotarIzq_Click" ToolTip="Rotar Izquierda" FontWeight="Bold" FontSize="16"/>
                    <Button Content="↻" Width="35" Height="35" Margin="3" Click="BtnRotarDer_Click" ToolTip="Rotar Derecha" FontWeight="Bold" FontSize="16"/>
                    <Button Content="-" Width="35" Height="35" Margin="3" Click="BtnZoomOut_Click" ToolTip="Alejar" FontWeight="Bold" FontSize="16"/>
                    <Button Content="+" Width="35" Height="35" Margin="3" Click="BtnZoomIn_Click" ToolTip="Acercar" FontWeight="Bold" FontSize="16"/>
                </StackPanel>

                <Button Content="SELECCIONAR FOTO" Width="160" Height="35" Click="BtnFoto_Click" FontWeight="Bold"/>
                
                <TextBlock Text="Usa los controles para ajustar la foto antes de guardar."
                           Foreground="#B0C4DE" FontSize="11" TextWrapping="Wrap" 
                           TextAlignment="Center" Margin="15,15,15,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Margin="35">
            <TextBlock Text="NUEVO REGISTRO" FontSize="26" FontWeight="Bold" Foreground="#00204A" Margin="0,0,0,25"/>

            <TextBlock Text="Matrícula Oficial:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtMatricula" Height="35" Margin="0,0,0,20" MaxLength="20" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock Text="Nombres:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombres" Height="35" Margin="0,0,0,20" CharacterCasing="Upper" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock Text="Apellidos:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtApellidos" Height="35" Margin="0,0,0,20" CharacterCasing="Upper" FontSize="14" VerticalContentAlignment="Center"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Grado:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbGrado" Height="35" IsEditable="False" FontSize="14" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Otro" Tag="1"/>
                        <ComboBoxItem Content="Marinero" Tag="2"/>
                        <ComboBoxItem Content="Cabo" Tag="3"/>
                        <ComboBoxItem Content="Tercer Maestre" Tag="4"/>
                        <ComboBoxItem Content="Segundo Maestre" Tag="5"/>
                        <ComboBoxItem Content="Primer Maestre" Tag="6"/>
                        <ComboBoxItem Content="Teniente de Corbeta" Tag="7"/>
                        <ComboBoxItem Content="Teniente de Fragata" Tag="8"/>
                        <ComboBoxItem Content="Teniente de Navío" Tag="9"/>
                        <ComboBoxItem Content="Capitán de Corbeta" Tag="10"/>
                        <ComboBoxItem Content="Capitán de Fragata" Tag="11"/>
                        <ComboBoxItem Content="Capitán de Navío" Tag="12"/>
                        <ComboBoxItem Content="Contralmirante" Tag="13"/>
                        <ComboBoxItem Content="Vicealmirante" Tag="14"/>
                        <ComboBoxItem Content="Almirante" Tag="15"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Jefatura / Adscripción:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbJefatura" Height="35" IsEditable="False" FontSize="14" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Otro" Tag="1"/>
                        <ComboBoxItem Content="Talleres" Tag="2"/>
                        <ComboBoxItem Content="Servicios" Tag="3"/>
                        <ComboBoxItem Content="Detall" Tag="4"/>
                        <ComboBoxItem Content="Comunav" Tag="5"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Border Background="#E8ECEF" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="70" Height="90" Background="White" BorderBrush="#00204A" BorderThickness="1" CornerRadius="3" ClipToBounds="True">
                        <Image x:Name="imgHuella" Stretch="UniformToFill"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtEstadoHuella" Text="Iniciando lector de huella..." FontWeight="Bold" FontSize="14" Foreground="Gray" Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="CANCELAR" Width="100" Height="35" Background="Gray" Foreground="White" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                            <Button Content="GUARDAR REGISTRO" Width="160" Height="35" Background="#00204A" Foreground="White" FontWeight="Bold" Click="BtnGuardar_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
        </StackPanel>
    </Grid>
</Window>