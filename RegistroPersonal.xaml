<Window x:Class="prueba1.RegistroPersonal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alta de Personal Naval (Multi-Biometría)" Height="650" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F8FAFC">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border x:Name="bdrFoto" Width="160" Height="190" Background="#1E293B" CornerRadius="8" Margin="0,0,0,15" ClipToBounds="True" BorderBrush="#334155" BorderThickness="2">
                    <Grid>
                        <TextBlock Text="👤" FontSize="80" Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="imgFoto" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="stEscala" ScaleX="1" ScaleY="1"/>
                                    <RotateTransform x:Name="rtRotacion" Angle="0"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Button Content="↺" Width="35" Height="35" Margin="3" Click="BtnRotarIzq_Click" ToolTip="Rotar Izquierda" FontWeight="Bold" FontSize="16" Background="#334155" Foreground="White"/>
                    <Button Content="↻" Width="35" Height="35" Margin="3" Click="BtnRotarDer_Click" ToolTip="Rotar Derecha" FontWeight="Bold" FontSize="16" Background="#334155" Foreground="White"/>
                    <Button Content="-" Width="35" Height="35" Margin="3" Click="BtnZoomOut_Click" ToolTip="Alejar" FontWeight="Bold" FontSize="16" Background="#334155" Foreground="White"/>
                    <Button Content="+" Width="35" Height="35" Margin="3" Click="BtnZoomIn_Click" ToolTip="Acercar" FontWeight="Bold" FontSize="16" Background="#334155" Foreground="White"/>
                </StackPanel>

                <Button Content="SELECCIONAR FOTO" Width="160" Height="40" Click="BtnFoto_Click" FontWeight="Bold" Background="#3B82F6" Foreground="White" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                
                <TextBlock Text="*La foto es opcional. El sistema usará un perfil genérico si no se adjunta."
                           Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" 
                           TextAlignment="Center" Margin="25,15,25,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Margin="40,30,40,30">
            <TextBlock Text="NUEVO REGISTRO" FontSize="26" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,25"/>

            <TextBlock Text="Matrícula Oficial:" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="txtMatricula" Height="38" Margin="0,0,0,15" MaxLength="20" FontSize="14" Padding="10,0"/>

            <TextBlock Text="Nombres:" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNombres" Height="38" Margin="0,0,0,15" CharacterCasing="Upper" FontSize="14" Padding="10,0"/>

            <TextBlock Text="Apellidos:" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="txtApellidos" Height="38" Margin="0,0,0,15" CharacterCasing="Upper" FontSize="14" Padding="10,0"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                <TextBlock Text="Grado:" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White">
                    <ComboBox x:Name="cmbGrado" Height="36" IsEditable="False" FontSize="14" BorderThickness="0" Background="Transparent" Padding="5,0"
                            DisplayMemberPath="NombreGrado" 
                            SelectedValuePath="IdGrado">
                        </ComboBox>
                </Border>
                </StackPanel>

                 <StackPanel Grid.Column="2">
                    <TextBlock Text="Jefatura / Adscripción:" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="White">
                        <ComboBox x:Name="cmbJefatura" Height="36" IsEditable="False" FontSize="14" BorderThickness="0" Background="Transparent" Padding="5,0"
                                DisplayMemberPath="NombreJefatura" 
                                SelectedValuePath="IdJefatura">
                        </ComboBox>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Background="#F1F5F9" CornerRadius="10" Padding="15" Margin="0,15,0,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="80" Height="100" Background="White" BorderBrush="#94A3B8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                        <Image x:Name="imgHuella" Stretch="UniformToFill"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SEGURIDAD MULTI-HUELLA" FontWeight="Black" Foreground="#0F172A" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtEstadoHuella" Text="Iniciando lector de huellas..." FontWeight="Bold" FontSize="15" Foreground="#3B82F6" Margin="0,0,0,15" TextWrapping="Wrap"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="CANCELAR" Width="100" Height="40" Background="#94A3B8" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Click="BtnCancelar_Click">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                            </Button>
                            <Button x:Name="btnGuardarRegistro" Content="GUARDAR REGISTRO" Width="170" Height="40" Background="#10B981" Foreground="White" FontWeight="Bold" Click="BtnGuardar_Click" IsEnabled="False">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
        </StackPanel>
    </Grid>
</Window>