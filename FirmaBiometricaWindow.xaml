<Window x:Class="prueba1.FirmaBiometricaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firma Biométrica" Height="400" Width="450"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Background="#0F172A">
    <Border BorderBrush="#3B82F6" BorderThickness="3" CornerRadius="15">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
            <TextBlock Text="🔒 FIRMA BIOMÉTRICA" Foreground="White" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Coloque su huella en el lector para autorizar." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <Border Width="120" Height="120" CornerRadius="60" Background="#1E293B" BorderBrush="#334155" BorderThickness="3" Margin="0,0,0,30">
                <TextBlock Text="⚓" FontSize="50" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <TextBlock x:Name="txtEstadoFirma" Text="Esperando lectura..." Foreground="#10B981" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <Button Content="CANCELAR OPERACIÓN" Background="#EF4444" Foreground="White" FontWeight="Bold" Height="40" Width="200" BorderThickness="0" Cursor="Hand" Click="BtnCancelar_Click">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>
