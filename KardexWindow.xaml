<Window x:Class="prueba1.KardexWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expediente Individual - Kardex" Height="700" Width="950"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ENCABEZADO CON FOTOGRAFÍA -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect><DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Fotografía Circular -->
                <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40" Background="#E2E8F0" BorderBrush="#CBD5E1" BorderThickness="1" ClipToBounds="True" Margin="0,0,20,0">
                    <Image x:Name="imgFotoKardex" Stretch="UniformToFill"/>
                </Border>
                
                <!-- Datos Personales -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="⚓ EXPEDIENTE OFICIAL DE:" FontSize="14" FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock x:Name="txtNombreMarino" Text="CARGANDO..." FontSize="24" FontWeight="Black" Foreground="#0F172A" Margin="0,2,0,2"/>
                    <TextBlock x:Name="txtDatosMarino" Text="-" FontSize="14" FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>

                <!-- Filtros movidos a la derecha para ahorrar espacio -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Del:" FontWeight="Bold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker x:Name="dpDesde" Width="110" Margin="0,0,15,0"/>
                    <TextBlock Text="Al:" FontWeight="Bold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker x:Name="dpHasta" Width="110" Margin="0,0,15,0"/>
                    <Button Content="🔍 Consultar" Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand" Click="BtnConsultar_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAPA DE ASISTENCIA (CALENDARIO VISUAL) -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Border.Effect><DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/></Border.Effect>
            <StackPanel>
                <TextBlock Text="Mapa de Asistencia del Período Seleccionado" FontSize="16" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>
                
                <ItemsControl x:Name="icCalendario">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- El cuadrito de color para cada día -->
                            <Border Width="35" Height="35" Margin="3" CornerRadius="6" Background="{Binding ColorFondo}" ToolTip="{Binding ToolTipInfo}">
                                <TextBlock Text="{Binding Dia}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding ColorTexto}" FontSize="14" FontWeight="Bold"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Simbología -->
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Border Width="12" Height="12" Background="#10B981" CornerRadius="2" Margin="0,0,5,0"/><TextBlock Text="Asistencia / Justificado" FontSize="12" Foreground="#64748B" FontWeight="Bold" Margin="0,0,20,0"/>
                    <Border Width="12" Height="12" Background="#EF4444" CornerRadius="2" Margin="0,0,5,0"/><TextBlock Text="Falta / Ausencia" FontSize="12" Foreground="#64748B" FontWeight="Bold" Margin="0,0,20,0"/>
                    <Border Width="12" Height="12" Background="#F1F5F9" CornerRadius="2" Margin="0,0,5,0"/><TextBlock Text="Futuro / Sin Evaluar" FontSize="12" Foreground="#64748B" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- TABLA DETALLADA DE HISTORIAL -->
        <Border Grid.Row="2" CornerRadius="12" Background="White" ClipToBounds="True">
            <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
            <DataGrid x:Name="dgHistorial" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                      Background="White" RowHeight="45" AlternatingRowBackground="#F8FAFC"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Padding" Value="15,10"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha del Evento" Binding="{Binding FechaHora}" Width="160" FontWeight="Bold"/>
                    
                    <DataGridTemplateColumn Header="Estado del Registro" Width="250">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- El color de esta etiqueta cambiará dinámicamente si es Falta o Asistencia -->
                                <TextBlock Text="{Binding MensajeAcceso}" Foreground="{Binding ColorTextoEstado}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Observaciones del Sistema o Guardia" Binding="{Binding NovedadMomento}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>