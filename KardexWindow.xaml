<Window x:Class="prueba1.KardexWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expediente Individual - Kardex" Height="600" Width="900"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚓ EXPEDIENTE DE: " FontSize="22" FontWeight="Bold" Foreground="#64748B"/>
                <TextBlock x:Name="txtNombreMarino" Text="CARGANDO..." FontSize="22" FontWeight="Black" Foreground="#0F172A" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Ver del:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dpDesde" Width="120" Margin="0,0,15,0"/>
            <TextBlock Text="Al:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dpHasta" Width="120" Margin="0,0,15,0"/>
            <Button Content="🔍 Consultar Historial" Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="15,5" BorderThickness="0" Cursor="Hand" Click="BtnConsultar_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgHistorial" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha y Hora" Binding="{Binding FechaHora}" Width="150"/>
                <DataGridTextColumn Header="Detalle del Registro" Binding="{Binding MensajeAcceso}" Width="450"/>
                <DataGridTextColumn Header="Observación" Binding="{Binding NovedadMomento}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>