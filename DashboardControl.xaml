<UserControl x:Class="prueba1.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="800"
             Background="Transparent">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Resumen de Estado de Fuerza (Hoy)" FontSize="22" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,20"/>

        <UniformGrid Grid.Row="1" Columns="4" VerticalAlignment="Top">
           <Border Cursor="Hand" MouseLeftButtonDown="Tarjeta_Click" Tag="TOTAL" Background="White" CornerRadius="15" Margin="10" Padding="20">
                <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="TOTAL PERSONAL" Foreground="#64748B" FontWeight="Bold" FontSize="12"/>
                    <TextBlock x:Name="txtTotal" Text="0" FontSize="36" FontWeight="Black" Foreground="#0F172A"/>
                    <TextBlock Text="Elementos Activos" Foreground="#94A3B8" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Cursor="Hand" MouseLeftButtonDown="Tarjeta_Click" Tag="PRESENTES" Background="White" CornerRadius="15" Margin="10" Padding="20" BorderBrush="#10B981" BorderThickness="0,0,0,4">
                <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="PRESENTES" Foreground="#10B981" FontWeight="Bold" FontSize="12"/>
                    <TextBlock x:Name="txtPresentes" Text="0" FontSize="36" FontWeight="Black" Foreground="#0F172A"/>
                    <ProgressBar x:Name="pbPresentes" Value="0" Maximum="100" Height="4" Margin="0,10,0,0" Foreground="#10B981"/>
                </StackPanel>
            </Border>

            <Border Cursor="Hand" MouseLeftButtonDown="Tarjeta_Click" Tag="FALTAS" Background="White" CornerRadius="15" Margin="10" Padding="20" BorderBrush="#EF4444" BorderThickness="0,0,0,4">
                <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="FALTISTAS" Foreground="#EF4444" FontWeight="Bold" FontSize="12"/>
                    <TextBlock x:Name="txtFaltas" Text="0" FontSize="36" FontWeight="Black" Foreground="#0F172A"/>
                    <TextBlock Text="Sin registro hoy" Foreground="#94A3B8" FontSize="11"/>
                </StackPanel>
            </Border>

            <Border Cursor="Hand" MouseLeftButtonDown="Tarjeta_Click" Tag="NOVEDADES" Background="White" CornerRadius="15" Margin="10" Padding="20" BorderBrush="#F59E0B" BorderThickness="0,0,0,4">
                <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="CON NOVEDAD" Foreground="#F59E0B" FontWeight="Bold" FontSize="12"/>
                    <TextBlock x:Name="txtNovedades" Text="0" FontSize="36" FontWeight="Black" Foreground="#0F172A"/>
                    <TextBlock Text="Comisión/Vacaciones" Foreground="#94A3B8" FontSize="11"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>