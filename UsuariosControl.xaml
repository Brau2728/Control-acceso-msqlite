<UserControl x:Class="prueba1.UsuariosControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestión de Accesos al Sistema" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Formulario Crear/Editar -->
            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="30" Margin="0,0,30,0" VerticalAlignment="Top">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="👤 Crear / Editar Usuario" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,25"/>

                    <TextBlock Text="Nombre de Usuario (Login):" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,20,0">
                        <TextBox x:Name="txtUserName" Height="40" Padding="10" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Contraseña:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,5,0">
                        <PasswordBox x:Name="txtUserPass" Height="40" Padding="10" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                    <TextBlock Text="(Déjalo en blanco si es edición)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <TextBlock Text="Nivel de Privilegios:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,30,0">
                        <ComboBox x:Name="cmbUserRol" Height="38" Padding="10" BorderThickness="0" Background="Transparent">
                            <ComboBoxItem Content="ADMIN"/>
                            <ComboBoxItem Content="GUARDIA"/>
                        </ComboBox>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="GUARDAR DATOS" Background="#10B981" Foreground="White" FontWeight="Bold" Height="45" Padding="15,0" Margin="0,0,10,0" Click="BtnGuardarUsuario_Click">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>
                        <Button Content="LIMPIAR" Background="#94A3B8" Foreground="White" FontWeight="Bold" Height="45" Padding="15,0" Click="BtnLimpiarUsuario_Click">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Tabla de Usuarios -->
            <Border Grid.Column="1" CornerRadius="16" Background="White" ClipToBounds="True">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <DataGrid x:Name="dgUsuarios" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="White" RowHeight="50" AlternatingRowBackground="#F8FAFC"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="15,15"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="150" IsReadOnly="True" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Rol Asignado" Binding="{Binding Rol}" Width="150" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Acciones del Sistema" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Content="✏️ Editar" Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="5,0" Padding="15,8" Click="BtnEditarUsuario_Click" CommandParameter="{Binding Id}">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                        <Button Content="🗑️ Revocar" Background="#EF4444" Foreground="White" FontWeight="Bold" Margin="5,0" Padding="15,8" Click="BtnEliminarUsuario_Click" CommandParameter="{Binding Id}">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>