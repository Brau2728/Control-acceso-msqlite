<UserControl x:Class="prueba1.GestionJefaturasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración del Organigrama y Áreas" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="25" Margin="0,0,30,0">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="🌳 Estructura Jerárquica Actual" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    
                    <TreeView x:Name="tvOrganigrama" Grid.Row="1" BorderThickness="0" SelectedItemChanged="TvOrganigrama_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Subramas}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="📁 " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding NombreJefatura}" FontSize="14" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="30" VerticalAlignment="Top">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="lblTituloForm" Text="➕ Crear Nueva Área / Rama" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,25"/>

                    <TextBlock Text="Nombre de la Jefatura / Departamento:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,20">
                        <TextBox x:Name="txtNombreArea" Height="40" Padding="10" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Depende de (Área Superior):" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,25">
                        <ComboBox x:Name="cmbAreaPadre" Height="38" Padding="10" BorderThickness="0" Background="Transparent" DisplayMemberPath="NombreJefatura" SelectedValuePath="IdJefatura"/>
                    </Border>

                    <StackPanel Orientation="Vertical">
                        <Button Content="GUARDAR ÁREA" Background="#10B981" Foreground="White" FontWeight="Bold" Height="45" Margin="0,0,0,10" Click="BtnGuardar_Click">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>
                        
                        <Button x:Name="btnEliminar" Content="🗑️ ELIMINAR ÁREA SELECCIONADA" Background="#EF4444" Foreground="White" FontWeight="Bold" Height="45" Margin="0,0,0,10" Visibility="Collapsed" Click="BtnEliminar_Click">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>

                        <Button Content="LIMPIAR / NUEVO" Background="#94A3B8" Foreground="White" FontWeight="Bold" Height="45" Click="BtnLimpiar_Click">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>