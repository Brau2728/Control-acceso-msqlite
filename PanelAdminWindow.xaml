<Window x:Class="prueba1.PanelAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:local="clr-namespace:prueba1"
        Title="Panel de Administración - Control de Acceso" 
        Height="768" Width="1366" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F8FAFC">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="0.5" CenterY="0.5"/></Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="primitives:DatePickerTextBox">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
        
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A" Panel.ZIndex="10">
            <StackPanel Margin="15,40,15,15">
                <TextBlock Text="⚓ SICB-GAN" Foreground="White" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="PANEL DE CONTROL" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button x:Name="BtnNuevoRegistroBtn" Content="➕ Nuevo Registro" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnNuevoRegistro_Click"/>
                <Button Content="📁 Directorio" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnDirectorio_Click"/>
                <Button Content="📊 Reportes y Cortes" Background="#F59E0B" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnReportes_Click"/>
                <Button x:Name="BtnUsuarios" Content="🔑 Accesos al Sistema" Background="#8B5CF6" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnUsuarios_Click"/>
                <Button x:Name="BtnConfiguracion" Content="⚙️ Sistema y Respaldos" Background="#475569" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnConfiguracion_Click"/>

                <Button Content="🚪 Cerrar Sesión" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,60,0,0" Click="BtnCerrarSesion_Click"/>
            </StackPanel>
        </Border>

        <Grid x:Name="PanelBienvenida" Grid.Column="1" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="SISTEMA INTEGRAL DE CONTROL BIOMÉTRICO" FontSize="36" FontWeight="Black" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                <TextBlock Text="Seleccione un módulo del menú lateral para operar" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="PanelDirectorio" Grid.Column="1" Visibility="Collapsed" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Directorio del Personal Naval" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,15"/>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <Border.Effect><DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/></Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Buscar Elemento:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#475569" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtBuscarPersonal" Width="250" Padding="8" Margin="0,0,30,0" TextChanged="FiltrosDirectorio_Changed"/>

                    <TextBlock Text="Filtrar por Estado:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#475569" Margin="0,0,10,0"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White">
                        <ComboBox x:Name="cmbFiltroNovedad" Width="180" Padding="8" BorderThickness="0" Background="Transparent" SelectionChanged="FiltrosDirectorio_Changed">
                            <ComboBoxItem Content="TODOS" IsSelected="True"/>
                            <ComboBoxItem Content="PRESENTE"/>
                            <ComboBoxItem Content="FALTISTA"/>
                            <ComboBoxItem Content="PERMISO"/>
                            <ComboBoxItem Content="VACACIONES"/>
                            <ComboBoxItem Content="COMISION"/>
                            <ComboBoxItem Content="HOSPITALIZADO"/>
                            <ComboBoxItem Content="REBAJADO"/>
                            <ComboBoxItem Content="FRANQUICIA"/>
                            <ComboBoxItem Content="GUARDIA"/>
                            <ComboBoxItem Content="ARRESTO"/>
                        </ComboBox>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" CornerRadius="12" Background="White" ClipToBounds="True">
                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                <DataGrid x:Name="dgPersonal" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="White" RowHeight="55" AlternatingRowBackground="#F8FAFC"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="Padding" Value="15,15"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Matrícula" Binding="{Binding Matricula}" Width="100"/>
                        <DataGridTextColumn Header="Grado" Binding="{Binding Grado}" Width="100"/>
                        <DataGridTextColumn Header="Nombre Completo" Binding="{Binding Nombre}" Width="160"/>
                        <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="160"/>
                        <DataGridTextColumn Header="Estatus" Binding="{Binding Estatus}" Width="90" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Novedad" Binding="{Binding Novedad}" Width="130" FontWeight="Bold"/>

                        <DataGridTemplateColumn Header="Acciones Operativas" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Content="👁️ Ver Perfil" Background="#1E293B" Foreground="White" FontWeight="Bold" Margin="4,0" Padding="12,8" Click="BtnVerPerfil_Click" CommandParameter="{Binding Matricula}"/>
                                        <Button Content="📌 Asignar Novedad" Background="#0284C7" Foreground="White" FontWeight="Bold" Margin="4,0" Padding="12,8" Click="BtnNovedad_Click" CommandParameter="{Binding Matricula}"/>
                                        <Button Content="✏️" ToolTip="Editar Datos" Visibility="{Binding VisibilidadAdmin, RelativeSource={RelativeSource AncestorType=Window}}" Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="4,0" Padding="12,8" Click="BtnEditarRegistro_Click" CommandParameter="{Binding Matricula}"/>
                                        <Button Content="🗑️" ToolTip="Eliminar Personal" Visibility="{Binding VisibilidadAdmin, RelativeSource={RelativeSource AncestorType=Window}}" Background="#EF4444" Foreground="White" FontWeight="Bold" Margin="4,0" Padding="12,8" Click="BtnEliminarRegistro_Click" CommandParameter="{Binding Matricula}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid x:Name="PanelReportes" Grid.Column="1" Visibility="Collapsed" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Módulo de Asistencia y Cortes de Turno" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,20"/>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="Padding" Value="20,12"/>
                        <Setter Property="Margin" Value="0,0,10,0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

               <TabItem Header="⏱️ Bitácora en Vivo">
    <Grid Background="White" Margin="0,15,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <local:DashboardControl x:Name="ucDashboard" Grid.Row="0"/>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="0,0,0,20" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,10,25,10">
                    <TextBlock Text="Matrícula:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtFiltroMatricula" Width="130" Height="38" Padding="10,0" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,25,10">
                    <TextBlock Text="Inicio:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <DatePicker x:Name="dpFechaInicio" Width="150" Height="38" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtHoraInicio" Width="80" Height="38" Text="00:00" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,25,10">
                    <TextBlock Text="Fin:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <DatePicker x:Name="dpFechaFin" Width="150" Height="38" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtHoraFin" Width="80" Height="38" Text="23:59" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <CheckBox x:Name="chkOcultarFallos" Content="Ocultar Fallos" VerticalAlignment="Center" FontWeight="Bold" Foreground="#64748B" Margin="0,10,25,10"/>

                <Button Content="🔍 Filtrar Datos" Height="40" Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="20,0" Margin="0,5,0,5" Click="BtnFiltrarBitacora_Click"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" CornerRadius="12" Background="White" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <DataGrid x:Name="dgBitacora" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      RowHeight="45" AlternatingRowBackground="#F8FAFC" Background="White"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="15,15"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha y Hora de Lectura" Binding="{Binding FechaHora}" Width="180"/>
                    <DataGridTextColumn Header="Matrícula" Binding="{Binding Matricula}" Width="120"/>
                    <DataGridTextColumn Header="Nombre del Elemento" Binding="{Binding NombreCompleto}" Width="300"/>
                    <DataGridTextColumn Header="Resultado Lector / Situación" Binding="{Binding MensajeAcceso}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</TabItem>
                <TabItem Header="📋 Generar Corte de Turno">
                    <Grid Background="White" Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#F0FDF4" CornerRadius="12" Margin="0,0,0,20" Padding="20,15">
    <Border.Effect><DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/></Border.Effect>
    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Margin="0,10,30,10">
            <TextBlock Text="Día a Evaluar:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpCorteFecha" Width="200"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10,30,10">
            <TextBlock Text="Turno De:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBox x:Name="txtCorteHoraInicio" Width="100" Text="07:00" Padding="8" TextAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10,30,10">
            <TextBlock Text="Tolerancia:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#EA580C" Margin="0,0,10,0"/>
            <TextBox x:Name="txtCorteHoraLimite" Width="100" Text="07:15" Padding="8" TextAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10,30,10">
            <TextBlock Text="Hasta:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBox x:Name="txtCorteHoraFin" Width="100" Text="17:00" Padding="8" TextAlignment="Center"/>
        </StackPanel>

        <Button Content="⚡ Calcular Estado de Fuerza" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="25,12" Margin="0,5,0,5" Click="BtnGenerarVistaPrevia_Click"/>
    </WrapPanel>
</Border>

                        <Border Grid.Row="1" CornerRadius="12" Background="White" ClipToBounds="True">
                            <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                            <DataGrid x:Name="dgCorteAsistencia" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      RowHeight="40" AlternatingRowBackground="#F8FAFC" Background="White"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0"
                                      MouseDoubleClick="dgCorteAsistencia_MouseDoubleClick" ToolTip="Doble clic en un elemento para justificar o auditar">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F1F5F9"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="15,10"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Matrícula" Binding="{Binding Matricula}" Width="120"/>
                                    <DataGridTextColumn Header="Grado" Binding="{Binding Grado}" Width="120"/>
                                    <DataGridTextColumn Header="Nombre Completo" Binding="{Binding NombreCompleto}" Width="280"/>
                                    <DataGridTextColumn Header="Jefatura" Binding="{Binding Jefatura}" Width="150"/>
                                    <DataGridTextColumn Header="SITUACIÓN" Binding="{Binding Situacion}" Width="*" FontWeight="Black"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                 <Grid Grid.Row="2" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="Notas Manuales del Guardia:" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtObservacionesCorte" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Padding="10" Background="#F8FAFC"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="15,0,30,0">
                                <TextBlock Text="Registro de Auditoría (Inalterable):" FontWeight="Bold" Foreground="#991B1B" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtAuditoriaSistema" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Padding="10" Background="#FEF2F2" Foreground="#991B1B" IsReadOnly="True" BorderBrush="#FECACA"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <TextBlock x:Name="txtResumenCorte" Text="Resumen: Esperando cálculo..." FontWeight="Black" FontSize="16" Foreground="#0F172A" Margin="0,0,0,10" HorizontalAlignment="Right"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="🔒 Firmar y Exportar PDF" Background="#EF4444" Foreground="White" FontWeight="Bold" Padding="20,12" Margin="0,0,10,0" Click="BtnExportarPDF_Click"/>
                                    <Button Content="🔒 Firmar y Exportar Excel" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="20,12" Click="BtnExportarExcel_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="📅 Reporte Concentrado">
                    <Grid Background="White" Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                       
                       <Border Grid.Row="0" Background="#EEF2FF" CornerRadius="12" Margin="0,0,0,20" Padding="20,15">
    <Border.Effect><DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/></Border.Effect>
    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Margin="0,10,30,10">
            <TextBlock Text="Rango De:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpConcentradoInicio" Width="200"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10,30,10">
            <TextBlock Text="Hasta:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpConcentradoFin" Width="200"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,10,40,10">
            <TextBlock Text="Hora Límite Entrada:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#EA580C" Margin="0,0,10,0"/>
            <TextBox x:Name="txtConcentradoTolerancia" Width="100" Text="07:15" Padding="8" TextAlignment="Center" ToolTip="Determina si es Retardo o Presente"/>
        </StackPanel>

        <Button Content="📊 Generar Matriz" Background="#4F46E5" Foreground="White" FontWeight="Bold" Padding="25,12" Margin="0,5,0,5" Click="BtnGenerarConcentrado_Click"/>
    </WrapPanel>
</Border>

                        <Border Grid.Row="1" CornerRadius="12" Background="White" ClipToBounds="True">
                            <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                            <DataGrid x:Name="dgConcentrado" AutoGenerateColumns="True" CanUserAddRows="False" IsReadOnly="True"
                                      RowHeight="35" AlternatingRowBackground="#F8FAFC" Background="White"
                                      HeadersVisibility="Column" GridLinesVisibility="All" HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="#E2E8F0" BorderThickness="0">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F1F5F9"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="10"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.Resources>
                            </DataGrid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,20,0,0">
                            <TextBlock x:Name="txtResumenConcentrado" Text="Seleccione un rango (Máx 31 días) y genere la matriz." FontWeight="Bold" FontSize="14" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Button Content="📗 Exportar Matriz a Excel" HorizontalAlignment="Right" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="20,12" Click="BtnExportarConcentradoExcel_Click"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="🗄️ Archivo Histórico">
    <TabControl Margin="0,10,0,0" Background="Transparent" BorderThickness="0">
        
        <TabItem Header="🟥 Cortes Oficiales (PDF)">
            <Grid Background="White" Margin="0,15,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="🔄 Actualizar Lista" Background="#3B82F6" Foreground="White" Padding="20,10" FontWeight="Bold" Click="BtnActualizarHistorial_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <Border Grid.Row="1" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <DataGrid x:Name="dgReportesPDF" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeight="50" AlternatingRowBackground="#F8FAFC" Background="White" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                        <DataGrid.Resources><Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#F1F5F9"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="15,15"/></Style></DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folio ID" Binding="{Binding IdReporte}" Width="80"/>
                            <DataGridTextColumn Header="Fecha de Creación" Binding="{Binding FechaGeneracion}" Width="160"/>
                            <DataGridTextColumn Header="Turno" Binding="{Binding Turno}" Width="150"/>
                            <DataGridTextColumn Header="Autorizó (Firma)" Binding="{Binding GeneradoPor}" Width="200"/>
                            <DataGridTextColumn Header="Ruta Oculta" Binding="{Binding RutaArchivo}" Width="*" Visibility="Hidden"/>
                            <DataGridTemplateColumn Header="Documento Oficial" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🟥 ABRIR PDF" Background="#EF4444" Foreground="White" FontWeight="Bold" Margin="5" Click="BtnAbrirDocumento_Click">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="🟩 Matrices Mensuales (Excel/XML)">
            <Grid Background="White" Margin="0,15,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="🔄 Actualizar Lista" Background="#3B82F6" Foreground="White" Padding="20,10" FontWeight="Bold" Click="BtnActualizarHistorial_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
                <Border Grid.Row="1" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <DataGrid x:Name="dgReportesExcel" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeight="50" AlternatingRowBackground="#F8FAFC" Background="White" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                        <DataGrid.Resources><Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#F1F5F9"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="15,15"/></Style></DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folio ID" Binding="{Binding IdReporte}" Width="80"/>
                            <DataGridTextColumn Header="Fecha de Creación" Binding="{Binding FechaGeneracion}" Width="160"/>
                            <DataGridTextColumn Header="Rango / Detalles" Binding="{Binding Turno}" Width="150"/>
                            <DataGridTextColumn Header="Generado Por" Binding="{Binding GeneradoPor}" Width="200"/>
                            <DataGridTextColumn Header="Ruta Oculta" Binding="{Binding RutaArchivo}" Width="*" Visibility="Hidden"/>
                            <DataGridTemplateColumn Header="Archivo Matriz" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🟩 ABRIR EXCEL" Background="#10B981" Foreground="White" FontWeight="Bold" Margin="5" Click="BtnAbrirDocumento_Click">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="📂 Explorador de Carpetas">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Seleccione la carpeta donde guarda sus respaldos y reportes" FontSize="18" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,20" TextAlignment="Center"/>
                <Button Content="📁 ELEGIR CARPETA PARA EXPLORAR" Background="#334155" Foreground="White" FontWeight="Black" FontSize="14" Padding="30,15" Click="BtnAbrirCarpeta_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </TabItem>

    </TabControl>
</TabItem>


            </TabControl>
        </Grid>

        <Grid x:Name="PanelUsuarios" Grid.Column="1" Visibility="Collapsed" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Gestión de Accesos al Sistema" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,20"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="30" Margin="0,0,30,0" VerticalAlignment="Top">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="👤 Crear / Editar Usuario" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,25"/>

                        <TextBlock Text="Nombre de Usuario (Login):" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtUserName" Height="40" Padding="10" Margin="0,0,0,20"/>

                        <TextBlock Text="Contraseña:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="txtUserPass" Height="40" Padding="10" Margin="0,0,0,5"/>
                        <TextBlock Text="(Déjalo en blanco si es edición)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <TextBlock Text="Nivel de Privilegios:" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,30,0">
                            <ComboBox x:Name="cmbUserRol" Height="38" Padding="10" BorderThickness="0" Background="Transparent">
                                <ComboBoxItem Content="ADMIN"/>
                                <ComboBoxItem Content="GUARDIA"/>
                            </ComboBox>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="GUARDAR DATOS" Background="#10B981" Foreground="White" FontWeight="Bold" Height="45" Padding="15,0" Margin="0,0,10,0" Click="BtnGuardarUsuario_Click"/>
                            <Button Content="LIMPIAR" Background="#94A3B8" Foreground="White" FontWeight="Bold" Height="45" Padding="15,0" Click="BtnLimpiarUsuario_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="16" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <DataGrid x:Name="dgUsuarios" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="White" RowHeight="50" AlternatingRowBackground="#F8FAFC"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" BorderThickness="0">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="15,15"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID Interno" Binding="{Binding Id}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nombre de Usuario" Binding="{Binding Username}" Width="200" IsReadOnly="True" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Rol de Acceso" Binding="{Binding Rol}" Width="180" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Acciones del Sistema" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="✏️ Editar" Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="5,0" Padding="15,8" Click="BtnEditarUsuario_Click" CommandParameter="{Binding Id}"/>
                                            <Button Content="🗑️ Revocar" Background="#EF4444" Foreground="White" FontWeight="Bold" Margin="5,0" Padding="15,8" Click="BtnEliminarUsuario_Click" CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="PanelConfiguracion" Grid.Column="1" Visibility="Collapsed" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Configuración General y Herramientas" FontSize="28" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,30"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Border Width="330" Background="White" CornerRadius="16" Padding="30" Margin="0,0,30,0">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <StackPanel>
                        <Border Background="#D1FAE5" Width="55" Height="55" CornerRadius="27" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <TextBlock Text="💾" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Exportar Base de Datos" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                        <TextBlock Text="Crea una copia local con la información biométrica y accesos." Foreground="#64748B" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="22"/>
                        <Button Content="GENERAR RESPALDO" Background="#10B981" Foreground="White" FontWeight="Bold" Height="48" Click="BtnExportarRespaldo_Click"/>
                    </StackPanel>
                </Border>

                <Border Width="330" Background="White" CornerRadius="16" Padding="30" Margin="0,0,30,0">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <StackPanel>
                        <Border Background="#DBEAFE" Width="55" Height="55" CornerRadius="27" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <TextBlock Text="📊" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Sincronizar Novedades" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                        <TextBlock Text="Sube una plantilla Excel (.xlsx) para actualizar masivamente el estado." Foreground="#64748B" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="22"/>
                        <Button Content="CARGAR EXCEL" Background="#3B82F6" Foreground="White" FontWeight="Bold" Height="48" Click="BtnImportarNovedadesExcel_Click"/>
                    </StackPanel>
                </Border>

                <Border Width="330" Background="White" CornerRadius="16" Padding="30">
                    <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Color="Black"/></Border.Effect>
                    <StackPanel>
                        <Border Background="#FEE2E2" Width="55" Height="55" CornerRadius="27" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <TextBlock Text="⚠️" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Restaurar Sistema" FontSize="20" FontWeight="Bold" Foreground="#991B1B" Margin="0,0,0,10"/>
                        <TextBlock Text="Sobreescribe el sistema actual con un archivo de respaldo." Foreground="#64748B" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="22"/>
                        <Button Content="IMPORTAR RESPALDO" Background="#EF4444" Foreground="White" FontWeight="Bold" Height="48" Click="BtnImportarRespaldo_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid x:Name="PanelNovedades" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#CC0F172A" Panel.ZIndex="100">
            <Border Background="White" Width="450" Height="400" CornerRadius="20" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40">
                <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.3" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="📋 ASIGNAR NOVEDAD" FontSize="24" FontWeight="Black" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                    <TextBlock Text="Matrícula Seleccionada:" Foreground="#64748B" FontSize="13" FontWeight="Bold"/>
                    <TextBlock x:Name="txtMatriculaNovedad" Text="-" FontSize="22" FontWeight="Black" Foreground="#3B82F6" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Estado General (Alta/Baja):" Foreground="#64748B" FontSize="13" FontWeight="Bold"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,5,0,20">
                        <ComboBox x:Name="cmbEstatus" FontSize="15" Padding="10" BorderThickness="0" Background="Transparent">
                            <ComboBoxItem Content="ACTIVO" Tag="ACTIVO"/>
                            <ComboBoxItem Content="BAJA" Tag="BAJA"/>
                        </ComboBox>
                    </Border>
                    
                    <TextBlock Text="Novedad del Elemento:" Foreground="#64748B" FontSize="13" FontWeight="Bold"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,5,0,35">
                        <ComboBox x:Name="cmbNovedad" FontSize="15" Padding="10" BorderThickness="0" Background="Transparent">
                            <ComboBoxItem Content="PRESENTE" Tag="PRESENTE"/>
                            <ComboBoxItem Content="FALTISTA" Tag="FALTISTA"/>
                            <ComboBoxItem Content="VACACIONES" Tag="VACACIONES"/>
                            <ComboBoxItem Content="PERMISO" Tag="PERMISO"/>
                            <ComboBoxItem Content="COMISION" Tag="COMISION"/>
                            <ComboBoxItem Content="HOSPITALIZADO" Tag="HOSPITALIZADO"/>
                            <ComboBoxItem Content="REBAJADO" Tag="REBAJADO"/>
                            <ComboBoxItem Content="FRANQUICIA" Tag="FRANQUICIA"/>
                            <ComboBoxItem Content="GUARDIA" Tag="GUARDIA"/>
                            <ComboBoxItem Content="ARRESTO" Tag="ARRESTO"/>
                        </ComboBox>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="APLICAR CAMBIOS" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" Padding="25,12" Margin="0,0,15,0" Click="BtnGuardarNovedad_Click"/>
                        <Button Content="CANCELAR" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="14" Padding="25,12" Click="BtnCancelarNovedad_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <Grid x:Name="PanelIncidencia" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#CC0F172A" Panel.ZIndex="100">
            <Border Background="White" Width="550" Height="320" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.3" Color="Black"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="⚖️ AUDITORÍA DE ASISTENCIA" FontSize="22" FontWeight="Black" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock x:Name="txtElementoJustificar" Text="Elemento: ---" FontSize="15" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Justificación del guardia (Ej. Lector falló, sí vino, etc.):" Foreground="#64748B" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNotaIncidencia" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Padding="10" Margin="0,0,0,25" Background="#F8FAFC"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="GUARDAR Y AUDITAR" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" Padding="20,12" Margin="0,0,15,0" Click="BtnGuardarJustificacion_Click"/>
                        <Button Content="CANCELAR" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="14" Padding="20,12" Click="BtnCancelarIncidencia_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>