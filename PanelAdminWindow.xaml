<Window x:Class="prueba1.PanelAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Administración - Control de Acceso" 
        Height="768" Width="1366" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F8FAFC">

    <Window.Resources>
        <!-- Estilo global de botones Material Design para el menú lateral -->
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL -->
        <Border Grid.Column="0" Background="#0F172A" Panel.ZIndex="10">
            <StackPanel Margin="15,40,15,15">
                <TextBlock Text="⚓ SICB-GAN" Foreground="White" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="PANEL DE CONTROL" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button x:Name="BtnNuevoRegistroBtn" Content="➕ Nuevo Registro" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnNuevoRegistro_Click"/>
                <Button Content="📁 Directorio" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnDirectorio_Click"/>
                <Button Content="☑️ Novedades Masivas" Background="#0EA5E9" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnNovedadesMasivas_Click"/>
                <Button Content="📊 Reportes y Cortes" Background="#F59E0B" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnReportes_Click"/>
                <Button Content="🌿 Gestionar Organigrama" Background="#0EA5E9" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnOrganigrama_Click"/>
                <Button Content="🎖️ Títulos y Grados" Background="#6366F1" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnGrados_Click"/>
                <Button x:Name="BtnUsuarios" Content="🔑 Accesos al Sistema" Background="#8B5CF6" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnUsuarios_Click"/>
                <Button x:Name="BtnSistema" Content="⚙️ Sistema y Respaldo" Background="#475569" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,5" Click="BtnSistema_Click"/>

                <Button Content="🚪 Cerrar Sesión" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15" Margin="0,40,0,0" Click="BtnCerrarSesion_Click"/>
            </StackPanel>
        </Border>

        <!-- CONTENEDOR DINÁMICO (AQUÍ SE INYECTAN LAS CLASES UserControl) -->
        <ContentControl x:Name="ContenedorPrincipal" Grid.Column="1" Margin="40">
            <!-- PANTALLA DE BIENVENIDA POR DEFECTO -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="SISTEMA INTEGRAL DE CONTROL BIOMÉTRICO" FontSize="36" FontWeight="Black" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                <TextBlock Text="Seleccione un módulo del menú lateral para operar" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </ContentControl>
    </Grid>
</Window>